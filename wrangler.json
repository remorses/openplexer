{
  "name": "openplexer",
  "main": "src/worker.ts",
  "minify": true,
  "compatibility_flags": ["nodejs_compat"],
  "compatibility_date": "2025-04-01",
  "kv_namespaces": [
    {
      "binding": "OPENPLEXER_KV",
      "id": "576aff8a55d14a43a4dcafe726cc858b"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "USER_STORE",
        "class_name": "UserStore"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["UserStore"]
    }
  ],
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.sql"],
      "fallthrough": true
    }
  ],
  "routes": [
    {
      "pattern": "openplexer.com",
      "custom_domain": true
    },
    {
      "pattern": "libsqlproxy.openplexer.com",
      "custom_domain": true
    }
  ],
  "env": {
    "preview": {
      "name": "openplexer-preview",
      "kv_namespaces": [
        {
          "binding": "OPENPLEXER_KV",
          "id": "f07fcdcadc4a4ca39a775be1a944d452"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "USER_STORE",
            "class_name": "UserStore"
          }
        ]
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["UserStore"]
        }
      ],
      "routes": [
        {
          "pattern": "preview.openplexer.com",
          "custom_domain": true
        },
        {
          "pattern": "libsqlproxy-preview.openplexer.com",
          "custom_domain": true
        }
      ]
    }
  }
}
